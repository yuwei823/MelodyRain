{
  "name": "melody-rain",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first animated sheet-music renderer",
  "type": "module",
  "engines": {
    "node": ">=20.19 <27"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "start": "node dist-server/index.js",
    "build": "npm run typecheck && npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deps:check": "npm ls --depth=0"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.10.1",
    "fflate": "^0.8.3",
    "opensheetmusicdisplay": "^2.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
